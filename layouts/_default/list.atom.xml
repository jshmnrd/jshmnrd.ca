{{- /* Atom feed template */ -}}

{{- $authorEmail := "" }}
{{- with site.Params.author }}
  {{- if reflect.IsMap . }}
    {{- with .email }}
      {{- $authorEmail = . }}
    {{- end }}
  {{- end }}
{{- else }}
  {{- with site.Author.email }}
    {{- $authorEmail = . }}
    {{- warnf "The author key in site configuration is deprecated. Use params.author.email instead." }}
  {{- end }}
{{- end }}

{{- $authorName := "" }}
{{- with site.Params.author }}
  {{- if reflect.IsMap . }}
    {{- with .name }}
      {{- $authorName = . }}
    {{- end }}
  {{- else }}
    {{- $authorName = . }}
  {{- end }}
{{- else }}
  {{- with site.Author.name }}
    {{- $authorName = . }}
    {{- warnf "The author key in site configuration is deprecated. Use params.author.name instead." }}
  {{- end }}
{{- end }}

{{- $pctx := . }}
{{- if .IsHome }}{{ $pctx = site }}{{ end }}

{{- $pages := slice }}
{{- if or $.IsHome $.IsSection }}
  {{- $pages = $pctx.RegularPages }}
{{- else }}
  {{- $pages = $pctx.Pages }}
{{- end }}

{{- $limit := site.Config.Services.RSS.Limit }}
{{- if ge $limit 1 }}
  {{- $pages = $pages | first $limit }}
{{- end }}

{{- $filteredPages := slice }}
{{- range $pages }}
  {{- if and (ne .Layout `search`) (ne .Layout `archives`) (ne .Layout `dev`) (ne .Layout `sitemap`) }}
    {{- $filteredPages = $filteredPages | append . }}
  {{- end }}
{{- end }}

{{- $feedTitle := cond (eq .Title site.Title) site.Title (printf "%s on %s" .Title site.Title) }}
{{- $updated := now }}
{{- with index $filteredPages.ByLastmod.Reverse 0 }}
  {{- $updated = .Lastmod }}
{{- end }}

{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ $feedTitle }}</title>
  <link href="{{ .Permalink }}" />
  {{- with .OutputFormats.Get "Atom" }}
  <link href="{{ .Permalink }}" rel="self" type="{{ .MediaType }}" />
  {{- end }}
  <id>{{ .Permalink }}</id>
  <updated>{{ $updated.Format "2006-01-02T15:04:05Z07:00" | safeHTML }}</updated>
  <generator uri="https://gohugo.io/">Hugo {{ hugo.Version }}</generator>

  {{- if or $authorName $authorEmail }}
  <author>
    {{- with $authorName }}
    <name>{{ . }}</name>
    {{- end }}
    {{- with $authorEmail }}
    <email>{{ . }}</email>
    {{- end }}
  </author>
  {{- end }}

  {{- with site.Copyright }}
  <rights>{{ . | markdownify | plainify | strings.TrimPrefix "© " }}</rights>
  {{- end }}

  {{- range $filteredPages }}
  <entry>
    <title>{{ .Title }}</title>
    <link href="{{ .Permalink }}" />
    <id>{{ .Permalink }}</id>
    <published>{{ .PublishDate.Format "2006-01-02T15:04:05Z07:00" | safeHTML }}</published>
    <updated>{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" | safeHTML }}</updated>

    {{- if or $authorName $authorEmail }}
    <author>
      {{- with $authorName }}
      <name>{{ . }}</name>
      {{- end }}
      {{- with $authorEmail }}
      <email>{{ . }}</email>
      {{- end }}
    </author>
    {{- end }}

    <summary type="html">{{ with .Description | html }}{{ . }}{{ else }}{{ .Summary | html }}{{ end }}</summary>

    {{- if and site.Params.ShowFullTextinRSS .Content }}
    <content type="html">{{ .Content | html }}</content>
    {{- end }}
  </entry>
  {{- end }}
</feed>